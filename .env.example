# Conan Exiles Docker stack defaults
# Copy this file to `.env` and adjust values.

# Persistent data is stored in Docker named volumes defined in docker-compose.yml

# Conan gameplay/network ports
CONAN_SERVER_PORT=7777
CONAN_RAW_UDP_PORT=7778
CONAN_QUERY_PORT=27015

# Server identity/gameplay
CONAN_SERVER_NAME=Conan Exiles Server
CONAN_MAX_PLAYERS=40
CONAN_REGION=0

# Security
CONAN_ADMIN_PASSWORD=changeme
CONAN_SERVER_PASSWORD=

# RCON (optional)
CONAN_RCON_ENABLED=false
CONAN_RCON_PORT=25575
CONAN_RCON_PASSWORD=

# SteamCMD update behavior
CONAN_UPDATE_ON_START=true
CONAN_VALIDATE_ON_START=false
STEAMCMD_LOGIN=anonymous
STEAMCMD_PASSWORD=

# Advanced Unreal launch flags
# Example: CONAN_EXTRA_ARGS=-NoBattlEye -MULTIHOME=192.168.1.10
CONAN_EXTRA_ARGS=
