# Conan Exiles Docker stack defaults
# Copy this file to `.env` and adjust values.

# Host bind-mount root used by docker-compose.yml (must exist and be writable by UID 1000)
CONAN_DATA_ROOT=/srv/docker-data/conan-exiles

# Conan gameplay/network ports
CONAN_SERVER_PORT=7777
CONAN_RAW_UDP_PORT=7778
CONAN_QUERY_PORT=27015

# Server identity/gameplay
CONAN_SERVER_NAME=Conan Exiles Server
CONAN_MAX_PLAYERS=40
CONAN_REGION=0

# Security
CONAN_ADMIN_PASSWORD=changeme
CONAN_SERVER_PASSWORD=

# RCON (optional)
CONAN_RCON_ENABLED=false
CONAN_RCON_PORT=25575
CONAN_RCON_PASSWORD=

# BattlEye toggle
# true  = pass -NoBattlEye to the server
# false = keep BattlEye enabled
CONAN_DISABLE_BATTLEYE=true

# Force direct-connect mode when Steam backend is unavailable.
# true  = pass -NOSTEAM (most reliable for joining; not listed in Steam browser)
# false = keep Steam backend enabled
CONAN_FORCE_NOSTEAM=false

# SteamCMD platform to install dedicated files for
CONAN_STEAMCMD_PLATFORM=linux

# SteamCMD update behavior
CONAN_UPDATE_ON_START=true
CONAN_VALIDATE_ON_START=false
STEAMCMD_LOGIN=anonymous
STEAMCMD_PASSWORD=

# Advanced Unreal launch flags
# Example: CONAN_EXTRA_ARGS=-NoBattlEye -MULTIHOME=192.168.1.10
# Bind to a specific LAN IP when behind NAT/firewall (e.g., OPNsense/pfSense)
# Example: CONAN_EXTRA_ARGS=-MULTIHOME=192.168.1.10
CONAN_EXTRA_ARGS=

# Optional: override Engine.ini build ID used for Steam listing grouping
# Default is 812257115 if not set
# CONAN_BUILD_ID_OVERRIDE=812257115

# Steam App ID used by OnlineSubsystemSteam (Engine.ini)
# Defaults to 443030 (Conan Exiles Dedicated Server)
# CONAN_STEAM_APP_ID=443030
